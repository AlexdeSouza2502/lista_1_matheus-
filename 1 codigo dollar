
#include <stdio.h>
#include <stdlib.h>
#include <locale.h>
int main (){
	setlocale(LC_ALL,"Portuguese");
	float dolar,real,dinheiro;
	printf("\nConversão para dolar");
	printf("\nDigite a Cotação do dolar hoje: ");
	scanf("%f",&dolar);
	
	printf("\nDigite o valor de reais, que tem disponível: ");
	scanf("%f",&real);
	dinheiro = real/dolar;
	
	printf("\nNa conversão você, tem %3.f dolares disponíveis",dinheiro);
	
	return 0;
}
